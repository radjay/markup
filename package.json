{
  "name": "markup",
  "version": "0.1.0",
  "description": "Native markdown editor for reviewing AI-generated plans and documents",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "check": "electron-vite build",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac --dir",
    "install-app": "npm run dist:dir && rm -rf ~/Applications/Markup.app && cp -R release/mac-arm64/Markup.app ~/Applications/Markup.app && echo 'Installed to ~/Applications/Markup.app'"
  },
  "build": {
    "appId": "com.markup.app",
    "productName": "Markup",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Markup"
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@electron-toolkit/utils": "^4.0.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
